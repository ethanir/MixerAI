# Copy this file to .env and fill in your real key.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: which Claude model to use for planning.
# Default is claude-opus-4-7 (strongest, ~$0.015/plan).
# Use claude-haiku-4-5-20251001 for cheap+fast planning (~$0.001/plan).
# PLANNER_MODEL=claude-opus-4-7
