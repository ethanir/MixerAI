# Copy this file to `.env` at the repo root before running `npm run build`.
#
# Plasmo only exposes env vars prefixed with PLASMO_PUBLIC_ to the client
# bundle. The PLANNER_URL is baked into the build at compile time.

# Production: point at your deployed Railway planner.
# Example:
#   PLASMO_PUBLIC_PLANNER_URL=https://mixerai-planner.up.railway.app/plan
#
# Local dev: leave unset (or omit this file entirely) — the extension will
# fall back to http://localhost:8000/plan.
PLASMO_PUBLIC_PLANNER_URL=
